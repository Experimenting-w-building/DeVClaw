# Runtime mode
NODE_ENV=development

# Master passphrase for encrypting secrets at rest
MASTER_KEY=

# Default LLM provider credentials (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Main agent model selection
MAIN_MODEL_PROVIDER=anthropic
MAIN_MODEL_NAME=claude-sonnet-4-20250514

# LLM request resilience
# LLM_TIMEOUT_MS=45000
# LLM_MAX_RETRIES=1

# Your Telegram user ID (only this user can interact with any bot)
OWNER_CHAT_ID=

# Main agent Telegram bot token
MAIN_BOT_TOKEN=

# Web dashboard
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=

# Optional comma-separated allowed origins for dashboard POST origin checks
# DASHBOARD_ALLOWED_ORIGINS=https://dashboard.example.com,https://admin.example.com

# Set to "true" to skip dashboard login (local dev only -- never use in production)
# DASHBOARD_SKIP_AUTH=

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# MCP Servers (optional) -- JSON array of server configs
# Each entry: {"name": "...", "command": "...", "args": ["..."], "env": {"KEY": "VAL"}}
# Example: [{"name": "filesystem", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]}]
MCP_SERVERS=

# Comma-separated agent names allowed to use MCP tools (default: main)
# MCP_TOOL_AGENTS=main

# Comma-separated host env vars exposed to MCP processes
# MCP_ENV_ALLOWLIST=PATH,HOME,SHELL,TMPDIR,LANG,LC_ALL

# WhatsApp channel (optional)
# Your WhatsApp phone number in JID format: <country><number>@s.whatsapp.net
# Example: 14155551234@s.whatsapp.net
# WHATSAPP_OWNER_JID=

# Sub-agent bot tokens are stored encrypted in the database.
# You provide them via Telegram when approving a new agent (/approve <name> <token>).
# No need to add them here.
